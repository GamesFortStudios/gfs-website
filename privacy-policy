<style>
:root{
  --bg:#0D1022;
  --surface:#151935;
  --surface-2:#1C2147;
  --line:#2A2F5A;
  --ink:#F0EFFA;
  --muted:#9CA0C0;
  --gold:#F5B82E;
  --gold-deep:#D99A0B;
  --violet:#6E5BFF;
  --radius:14px;
  --disp:'Unbounded',sans-serif;
  --body:'Instrument Sans',system-ui,sans-serif;
  --mono:'JetBrains Mono',monospace;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--ink);font-family:var(--body);font-size:17px;line-height:1.65;
  background-image:radial-gradient(ellipse 80% 50% at 50% -10%,rgba(110,91,255,.14),transparent),
  repeating-linear-gradient(0deg,transparent,transparent 39px,rgba(255,255,255,.015) 40px);}
a{color:inherit;text-decoration:none}
:focus-visible{outline:2px solid var(--gold);outline-offset:3px;border-radius:4px}
.wrap{max-width:900px;margin:0 auto;padding:0 24px}
img{max-width:100%;display:block}

.quest{font-family:var(--mono);font-size:12.5px;letter-spacing:.14em;color:var(--gold);text-transform:uppercase;display:flex;align-items:center;gap:10px;margin-bottom:18px}
.quest::before{content:"▸";color:var(--violet)}

/* ===== NAV ===== */
header{position:sticky;top:0;z-index:50;background:rgba(13,16,34,.82);backdrop-filter:blur(14px);border-bottom:1px solid var(--line)}
.nav{display:flex;align-items:center;justify-content:space-between;height:72px;max-width:1180px;margin:0 auto;padding:0 24px}
.logo{font-family:var(--disp);font-weight:900;font-size:17px;display:flex;align-items:center;gap:11px}
.logo img{height:44px;width:auto}
.btn{display:inline-block;font-weight:600;font-size:15px;padding:13px 26px;border-radius:10px;transition:transform .15s,box-shadow .15s;border:0;cursor:pointer;font-family:var(--body)}
.btn-ghost{border:1px solid var(--line);color:var(--ink);background:transparent}
.btn-ghost:hover{border-color:var(--gold);color:var(--gold)}

/* ===== HERO ===== */
.phead{padding:80px 0 44px;border-bottom:1px solid var(--line)}
.phead h1{font-family:var(--disp);font-weight:900;font-size:clamp(30px,5vw,48px);line-height:1.12;letter-spacing:-.015em;margin-bottom:16px}
.phead h1 em{font-style:normal;color:var(--gold)}
.updated{font-family:var(--mono);font-size:13px;color:var(--muted)}
.updated b{color:var(--gold)}

/* ===== TOC ===== */
.toc{background:var(--surface);border:1px solid var(--line);border-radius:var(--radius);padding:28px 30px;margin:48px 0}
.toc h2{font-family:var(--mono);font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:16px}
.toc ol{list-style:none;counter-reset:t;columns:2;column-gap:36px}
.toc li{counter-increment:t;margin-bottom:11px;break-inside:avoid}
.toc a{color:var(--muted);font-size:15px;transition:color .2s}
.toc a::before{content:counter(t,decimal-leading-zero);font-family:var(--mono);font-size:12px;color:var(--violet);margin-right:10px}
.toc a:hover{color:var(--gold)}

/* ===== BODY ===== */
.doc{padding:20px 0 40px}
.doc section{padding:40px 0;border-bottom:1px solid var(--line)}
.doc section:last-child{border-bottom:0}
.doc h2{font-family:var(--disp);font-weight:700;font-size:clamp(21px,2.6vw,28px);line-height:1.2;letter-spacing:-.01em;margin-bottom:8px;scroll-margin-top:90px}
.doc h2 .n{font-family:var(--mono);font-size:14px;color:var(--gold);font-weight:600;margin-right:12px;vertical-align:middle}
.doc h3{font-family:var(--disp);font-weight:500;font-size:17px;margin:26px 0 10px}
.doc p{color:var(--muted);margin-bottom:16px}
.doc a.inline{color:var(--gold);text-decoration:underline;text-underline-offset:3px}
.doc ul{list-style:none;margin:0 0 16px}
.doc li{padding:8px 0 8px 30px;position:relative;color:var(--muted)}
.doc li::before{content:"✦";position:absolute;left:4px;color:var(--gold)}
.doc strong{color:var(--ink);font-weight:600}
.callout{background:var(--surface);border:1px solid var(--line);border-left:3px solid var(--gold);border-radius:12px;padding:22px 26px;margin:22px 0}
.callout p{margin:0;color:var(--ink)}

/* ===== FOOTER ===== */
footer{border-top:1px solid var(--line);padding:50px 0 40px;background:rgba(0,0,0,.22)}
.fnav{display:flex;flex-wrap:wrap;gap:22px;margin-bottom:26px}
.fnav a{color:var(--muted);font-size:14.5px}
.fnav a:hover{color:var(--gold)}
.copy{font-family:var(--mono);font-size:12.5px;color:var(--muted);border-top:1px solid var(--line);padding-top:26px;text-align:center}

@media(max-width:640px){
  .toc ol{columns:1}
  .nav .btn{display:none}
}
</style>
</head>
